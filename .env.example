# ── LLM Provider Configuration ──────────────────────────────────────────
# Options: claude-proxy, claude-proxy-alt, openai-proxy,
#          anthropic-api, openai-api, gemini, ollama
#
# Leave empty for basic scoring only (no AI features, but search works fine)
LLM_PROVIDER=claude-proxy

# Override defaults (optional — presets fill these automatically)
# LLM_BASE_URL=http://localhost:8317/v1
# LLM_API_KEY=not-needed
# LLM_MODEL=claude-sonnet-4-20250514

# For direct API providers (anthropic-api, openai-api, gemini), set the key:
# LLM_API_KEY=your-api-key-here

# ── Optional ────────────────────────────────────────────────────────────
# Serper API for web search (used by company research when LLM is active)
# Get one at https://serper.dev (free tier: 2500 queries)
# SERPER_API_KEY=your-serper-key-here
