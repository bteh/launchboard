# ── Launchboard Configuration ──────────────────────────────────────────
#
# Copy this file to .env:  cp .env.example .env
# Or just run: make setup (does this automatically)
#
# AI is optional for basic search, but recommended for the full experience.

# ── AI Provider ──────────────────────────────────────────────────────
# Easiest: set up in the web UI (Settings page). Or configure here.
#
# FREE TIER options (limits change — check each provider's pricing page):
#   gemini        — Google Gemini (aistudio.google.com/apikey)
#   groq          — Groq (console.groq.com/keys)
#   cerebras      — Cerebras (cloud.cerebras.ai)
#   openrouter    — OpenRouter (openrouter.ai/keys)
#   mistral       — Mistral (console.mistral.ai)
#   ollama        — Local models via Ollama (no account, fully offline)
#
# PAID options:
#   openai-api    — OpenAI API (separate from ChatGPT Plus)
#   anthropic-api — Anthropic API (separate from Claude Pro)
#   deepseek      — DeepSeek (free credits, then cheap)
#   sambanova     — SambaNova ($5 free trial)
#
LLM_PROVIDER=

# API key (required for cloud providers, not needed for Ollama)
# LLM_API_KEY=your-key-here

# Override model (optional — each provider has a sensible default)
# LLM_MODEL=gemini-2.5-flash

# Override base URL (optional — for OpenAI-compatible endpoints)
# LLM_BASE_URL=http://localhost:11434/v1

# ── Backend ───────────────────────────────────────────────────────────
# CORS origins (comma-separated, default: http://localhost:5173,http://localhost:3000)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend API URL (only needed for non-default setups)
# VITE_API_URL=http://localhost:8000/api/v1

# Hosted-like local sandbox (optional)
# Set HOSTED_MODE=true and DEV_HOSTED_AUTH=true to run the local persona sandbox.
# HOSTED_MODE=false
# DEV_HOSTED_AUTH=false
# DEV_HOSTED_AUTH_SECRET=launchboard-dev-hosted-auth-secret-key
# DEV_HOSTED_PERSONAS_PATH=./docs/dev-personas.example.json

# ── Data Storage ──────────────────────────────────────────────────────
# Where to store the SQLite database (default: ./data/)
# JOB_FINDER_DATA_DIR=./data
