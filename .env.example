# ── Launchboard Configuration ──────────────────────────────────────────
#
# Copy this file to .env:  cp .env.example .env
#
# LLM is OPTIONAL — search and basic scoring work without it.
# Only needed for: AI scoring, cover letters, company research.

# ── LLM Provider ──────────────────────────────────────────────────────
# Pick ONE provider. Leave LLM_PROVIDER empty to run without AI.
#
# FREE options:
#   gemini        — Google Gemini (free tier: 15 req/min)
#   ollama        — Local models via Ollama (requires: brew install ollama)
#
# PAID options:
#   openai-api    — OpenAI API (requires API key)
#   anthropic-api — Anthropic API (requires API key)
#
# LOCAL PROXY options (for developers):
#   claude-proxy  — Claude Code CLI proxy (http://localhost:8317)
#   openai-proxy  — OpenAI Codex proxy (http://localhost:8741)
#
LLM_PROVIDER=

# API key (required for gemini, openai-api, anthropic-api)
# LLM_API_KEY=your-api-key-here

# Override model (optional — each provider has a sensible default)
# LLM_MODEL=gemini-2.5-flash

# Override base URL (optional — only for custom endpoints)
# LLM_BASE_URL=http://localhost:11434/v1

# ── Backend ───────────────────────────────────────────────────────────
# CORS origins (comma-separated, default: http://localhost:5173,http://localhost:3000)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend API URL (only needed for non-default setups)
# Set VITE_API_URL in frontend/.env for the React app
# VITE_API_URL=http://localhost:8000/api/v1

# ── Data Storage ──────────────────────────────────────────────────────
# Where to store the SQLite database (default: ./data/)
# JOB_FINDER_DATA_DIR=./data
