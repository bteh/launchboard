# Environment
.env
.env.*
!.env.example
.venv/
venv/

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Resumes (user-specific, not tracked)
knowledge/*.pdf
knowledge/*.docx
knowledge/.*_resume_name
backend/knowledge/*.pdf
backend/knowledge/*.docx
backend/knowledge/.*_resume_name

# User profiles (personal config — only _template.yaml is tracked)
src/job_finder/config/profiles/*.yaml
!src/job_finder/config/profiles/_template.yaml

# Data
data/*.db
data/*.sqlite
**/*.db

# Output
src/job_finder/output/*.json
src/job_finder/output/*.md

# Frontend
frontend/node_modules/
frontend/dist/

# OS
.DS_Store
Thumbs.db

# Claude / Tooling
.claude/

# Stray pip artifacts
=*
data/workspaces/
data/settings_audit.log
