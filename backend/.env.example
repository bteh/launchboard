# Launchboard backend configuration

# Core runtime
HOSTED_MODE=false
DEV_HOSTED_AUTH=false
DEV_HOSTED_AUTH_SECRET=launchboard-dev-hosted-auth-secret-key
DEV_HOSTED_PERSONAS_PATH=
DATABASE_URL=
MANAGE_SCHEMA_ON_STARTUP=
DATA_DIR=data
WORKSPACE_STORAGE_DIR=

# Local/self-host AI (used by local mode, or as the hosted platform-managed provider)
LLM_PROVIDER=
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
ALLOW_RUNTIME_LLM_CONFIG=true
HOSTED_PLATFORM_MANAGED_AI=true
HOSTED_ALLOW_WORKSPACE_LLM_CONFIG=false

# Supabase hosted auth + storage
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=launchboard-private
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=

# Hosted worker tuning
WORKER_ID=
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_LEASE_SECONDS=120
WORKER_RETRY_BASE_SECONDS=15
