{
  "name": "@launchboard/frontend",
  "private": true,
  "version": "0.2.0",
  "description": "Launchboard web frontend — React + TanStack Router + Tailwind",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "desktop:dev": "tauri dev",
    "desktop:dev:web": "cross-env VITE_API_URL=http://127.0.0.1:8765/api/v1 vite --host 127.0.0.1 --port 5173",
    "desktop:smoke": "node ./scripts/run-desktop-smoke.mjs",
    "desktop:smoke:install": "playwright install chromium",
    "desktop:generate-icons": "tauri icon ./src-tauri/app-icon.svg -o ./src-tauri/icons",
    "desktop:prepare:sidecar": "node ./scripts/prepare-desktop-sidecar.mjs",
    "desktop:build": "node ./scripts/run-desktop-build.mjs",
    "desktop:build:web": "cross-env VITE_API_URL=http://127.0.0.1:8765/api/v1 npm run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate-types": "openapi-typescript http://localhost:8000/openapi.json -o src/types/api.generated.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.58.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.166.3",
    "@tanstack/react-table": "^8.21.3",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.0",
    "shadcn": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tauri-plugin-mcp": "^0.1.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.59.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
