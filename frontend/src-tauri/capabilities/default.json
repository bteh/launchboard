{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "default",
  "description": "Default desktop capability for Launchboard.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://**" },
        { "url": "http://**" }
      ]
    }
  ]
}
