{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Launchboard",
  "version": "0.2.0",
  "identifier": "com.launchboard.desktop",
  "build": {
    "beforeDevCommand": "npm run desktop:dev:web",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run desktop:build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Launchboard",
        "width": 1480,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": {
      "../../.desktop-build/tauri-sidecars/*": "sidecars/"
    },
    "targets": "all",
    "macOS": {
      "signingIdentity": "-",
      "entitlements": null
    }
  }
}
